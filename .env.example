# Server
PORT=3000
EXPOSE_DEBUG_ERRORS=false

# Gemini (required for Video AI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cerebras (fast text provider)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Groq (fallback fast text provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# TwelveLabs (video indexing)
TWELVELABS_API_KEY=
TWELVELABS_MODEL=pegasus1.5

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Diagnostic API key — must be a long random secret (24+ chars)
DIAGNOSTIC_API_KEY=

# Email for site notifications
SITE_NOTIFY_EMAIL=
SITE_NOTIFY_BACKEND_EMAIL=false

# OpenCV tracker (optional)
USE_OPENCV_TRACKER=false
TRACKER_PYTHON=python
TRACKER_SERVICE_URL=
-e 
# Admin user email (controls admin-only pages and features)
VITE_ADMIN_EMAIL=awang03@dccs.org
