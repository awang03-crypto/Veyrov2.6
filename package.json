{
  "name": "match-rating-video-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "frontend": "vite --config vite.config.js --host 0.0.0.0",
    "build": "vite build --config vite.config.js",
    "check": "node --check server.js",
    "lint": "node scripts/lint.mjs",
    "secret-scan": "node scripts/secret-scan.mjs",
    "test": "node --test tests/*.test.js",
    "coverage": "node scripts/check-coverage.mjs",
    "audit": "npm audit --audit-level=critical",
    "docker:build": "docker build -t veyro .",
    "docker:run": "docker run -p 3000:3000 --env-file .env veyro",
    "test:react": "vitest run --config vitest.config.js",
    "test:react:watch": "vitest --config vitest.config.js",
    "test:react:coverage": "vitest run --config vitest.config.js --coverage",
    "test:all": "npm test && npm run test:react"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "multer": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4",
    "stripe": "^22.2.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.0.0",
    "jsdom": "^25.0.0"
  }
}
